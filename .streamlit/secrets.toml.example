# .streamlit/secrets.toml
# ──────────────────────────────────────────────────────────────────────────────
# Google Earth Engine Service Account credentials
# Required for Streamlit Cloud deployment
# For LOCAL development: run `earthengine authenticate` instead — leave blank
#
# HOW TO GET THESE:
# 1. Go to https://console.cloud.google.com/
# 2. Create a project (or use existing)
# 3. Enable Earth Engine API
# 4. Create a Service Account (IAM & Admin → Service Accounts)
# 5. Download JSON key for the service account
# 6. Register the service account email at https://signup.earthengine.google.com/
# 7. Paste values below

GEE_SERVICE_ACCOUNT = "your-service-account@your-project.iam.gserviceaccount.com"

# Paste the ENTIRE content of the downloaded JSON key file as a string:
GEE_KEY_JSON = '''
{
  "type": "service_account",
  "project_id": "your-project-id",
  "private_key_id": "...",
  "private_key": "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n",
  "client_email": "your-service-account@your-project.iam.gserviceaccount.com",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token"
}
'''
